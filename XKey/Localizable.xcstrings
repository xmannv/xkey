    "Khi bật, cửa sổ Debug sẽ tự động hiển thị mỗi khi khởi động XKey": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, Debug window will automatically show on XKey startup"
          }
        },
