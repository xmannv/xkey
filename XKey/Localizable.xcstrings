        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Translation will be copied to clipboard for pasting elsewhere."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "翻译将被复制到剪贴板，以便粘贴到其他地方。"
