        }
      }
    },
    "iCloud Sync không khả dụng": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Sync unavailable"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 同步不可用"
          }
        }
      }
    },
    "Vui lòng đăng nhập iCloud và bật iCloud Drive trên máy này. Trên macOS 26+, một số phiên bản phân phối ngoài App Store có thể tạm thời không hỗ trợ iCloud Sync.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please sign in to iCloud and enable iCloud Drive on this Mac. On macOS 26+, some non-App Store distributions may temporarily not support iCloud Sync."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在本机登录 iCloud 并启用 iCloud Drive。在 macOS 26+ 上，部分非 App Store 分发版本可能暂不支持 iCloud 同步。"
          }
        }
      }
    },
    "Export từ iCloud": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
